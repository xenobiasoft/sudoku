@page "/create-profile"

<PageTitle>Choose Your Alias</PageTitle>

<div class="create-profile-container">
    <div class="create-profile-card">
        <h1>Choose Your Alias</h1>
        <p class="subtitle">Pick a unique name to identify yourself.</p>

        <EditForm Model="@_model" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label for="alias">Alias</label>
                <InputText id="alias" @bind-Value="_model.Alias" class="@(_hasError ? "form-control is-invalid" : "form-control")"
                           placeholder="e.g. sudoku master" maxlength="50" />
                <ValidationMessage For="@(() => _model.Alias)" />
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="error-message" role="alert">@_errorMessage</div>
                }
                <small class="form-hint">2–50 characters · letters, numbers, and spaces only</small>
            </div>

            <button type="submit" class="btn-primary" disabled="@_isSubmitting">
                @(_isSubmitting ? "Creating…" : "Create Profile")
            </button>
        </EditForm>

        <p class="warning-note">
            Your profile is stored in this browser. Clearing browser data will require you to create a new profile.
        </p>
    </div>
</div>
