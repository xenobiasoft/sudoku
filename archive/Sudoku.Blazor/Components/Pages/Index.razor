@page "/"

<PageTitle>Home</PageTitle>

<IndexErrorBoundary>
    <div class="landing-page">
        <SudokuImage />
        <div class="cards">
            <button class="card @(!_isReturningPlayer ? "card-primary" : "")" @onclick="NavigateToProfile">
                <span><i class="fa-solid fa-user"></i> @(_isReturningPlayer ? "Manage Profile" : "Create Profile")</span>
            </button>

            <button class="card @(!_isReturningPlayer ? "card-disabled" : "")"
                    @onclick="NavigateToSelectDifficulty"
                    disabled="@(!_isReturningPlayer)"
                    aria-disabled="@(!_isReturningPlayer)">
                <span><i class="fa-solid fa-play-circle"></i> Start New Game</span>
                @if (!_isReturningPlayer)
                {
                    <span class="helper-text">Create a profile to unlock this</span>
                }
            </button>

            <button class="card @(!_isReturningPlayer ? "card-disabled" : "")"
                    @onclick="NavigateToGameList"
                    disabled="@(!_isReturningPlayer)"
                    aria-disabled="@(!_isReturningPlayer)">
                <span><i class="fa-solid fa-folder-open"></i> Browse Game List</span>
                @if (!_isReturningPlayer)
                {
                    <span class="helper-text">Create a profile to unlock this</span>
                }
            </button>
        </div>
    </div>
</IndexErrorBoundary>
